{
  "name": "@wahya/flutterwave-v4-node-sdk",
  "version": "0.1.0",
  "description": "TypeScript Node.js SDK for the Flutterwave v4 API",
  "repository": {
    "url": "https://github.com/Wahya-pay/flutterwave-v4-node-sdk",
    "type": "git"
  },
  "license": "MIT",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test:types": "tsc -p tsconfig.api-surface.json",
    "test": "vitest run",
    "prepublishOnly": "npm run build && npm run typecheck && npm run test:types && npm run test"
  },
  "keywords": [
    "flutterwave",
    "sdk",
    "payments",
    "node",
    "typescript"
  ],
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsup": "^8.2.4",
    "typescript": "^6.0.3",
    "vitest": "^3.2.4"
  }
}